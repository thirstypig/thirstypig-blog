{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:year(\\d{4})/:month(\\d{2})/:day(\\d{2})/:slug/",
      "destination": "/posts/:year-:month-:day-:slug/",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/posts/:path*",
      "permanent": true
    }
  ]
}
