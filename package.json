{
  "name": "thirstypig",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "validate:hitlist": "node --input-type=module -e \"import{readFileSync}from'fs';import{parse}from'yaml';parse(readFileSync('src/data/places-hitlist.yaml','utf8'));console.log('Hit List YAML valid')\"",
    "build": "npm run validate:hitlist && npx tinacms build --skip-cloud-checks && cp tina/admin-custom.css public/admin/custom.css && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tinacms/cli": "^2.2.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.2",
    "tinacms": "^3.7.0"
  }
}
