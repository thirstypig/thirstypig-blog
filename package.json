{
  "name": "thirstypig",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "validate:hitlist": "node scripts/validate_hitlist.mjs",
    "fetch:webmentions": "node --env-file-if-exists=.env.local scripts/fetch-webmentions.mjs",
    "build": "npm run validate:hitlist && npm run fetch:webmentions && npx tinacms build --skip-cloud-checks && cp tina/admin-custom.css public/admin/custom.css && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run typecheck && npm run test:unit && npm run test:py && npm run test:e2e",
    "typecheck": "NODE_OPTIONS=\"--max-old-space-size=4096\" tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:py": "python3 -m pytest scripts/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup:hooks": "git config core.hooksPath .githooks && echo 'Pre-commit hook active. Bypass once with: git commit --no-verify'"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tinacms/cli": "^2.2.0",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.0",
    "leaflet": "^1.9.4",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.2",
    "tinacms": "^3.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@types/google.maps": "^3.64.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
