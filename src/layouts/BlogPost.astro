---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { slugify } from '../utils';
import FormattedDate from '../components/FormattedDate.astro';
import LocationCard from '../components/LocationCard.astro';
import VenueTags from '../components/VenueTags.astro';
import ImageGallery from '../components/ImageGallery.astro';
import AdSlot from '../components/AdSlot.astro';
import { getImageInfo } from '../utils/image-dimensions.mjs';

type Props = CollectionEntry<'posts'>['data'];

const {
	title,
	description,
	pubDate,
	heroImage,
	images = [],
	categories = [],
	tags = [],
	author,
	source,
	originalUrl,
	location,
	city,
	region,
	address,
	coordinates,
	placeId,
} = Astro.props;

const heroInfo = heroImage ? await getImageInfo(heroImage) : null;
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage}
	type="article"
	publishDate={pubDate}
	categories={categories}
	location={location}
	address={address}
	coordinates={coordinates}
	city={city}
	region={region}
>
	<article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
		<!-- Header -->
		<header class="mb-6">
			{categories.length > 0 && (
				<div class="flex flex-wrap gap-2 mb-4">
					{categories.map(cat => (
						<a
							href={`/categories/${slugify(cat)}/`}
							class="text-xs font-medium text-amber bg-amber/10 px-2.5 py-1 rounded-full hover:bg-amber/20 transition-colors no-underline"
						>
							{cat}
						</a>
					))}
				</div>
			)}
			<h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-ink leading-tight mb-4">
				{title}
			</h1>
			<div class="flex items-center gap-3 text-sm text-stone">
				<span>By {author || 'The Thirsty Pig'}</span>
				<span class="text-cream-dark">&bull;</span>
				<FormattedDate date={pubDate} />
			</div>
		</header>

		<!-- Location Card -->
		<LocationCard
			location={location}
			city={city}
			region={region}
			address={address}
			coordinates={coordinates}
		/>

		<!-- Venue chips (renders only when placeId has chip data published) -->
		<VenueTags placeId={placeId} />

		<!-- Ad: between location card and content -->
		<AdSlot format="horizontal" />

		<!-- Content -->
		<div class="prose max-w-none">
			<slot />
		</div>

		<!-- Ad: after post content -->
		<AdSlot format="article" />

		<!-- Hero Image (constrained height) -->
		{heroImage && heroInfo && (
			<div class="hero-container mb-6 -mx-4 sm:mx-0">
				<picture>
					{heroInfo.webp && <source type="image/webp" srcset={heroInfo.webp} />}
					<img
						src={heroImage}
						alt={title}
						width={heroInfo.width ?? undefined}
						height={heroInfo.height ?? undefined}
						class="w-full rounded-none sm:rounded-xl shadow-lg hero-image"
						loading="lazy"
						decoding="async"
						fetchpriority="low"
					/>
				</picture>
			</div>
		)}

		<!-- Image Gallery (additional images beyond hero) -->
		<ImageGallery images={images} heroImage={heroImage} title={title} />

		<!-- Tags -->
		{tags.length > 0 && (
			<div class="mt-10 pt-6 border-t border-cream-dark">
				<div class="flex flex-wrap gap-2 items-center">
					<span class="text-sm text-stone mr-1">Tags:</span>
					{tags.map(tag => (
						<span class="text-xs text-stone bg-cream-dark px-2.5 py-1 rounded-full">
							{tag}
						</span>
					))}
				</div>
			</div>
		)}

		<!-- Source attribution -->
		{originalUrl && (
			<div class="mt-6 text-xs text-stone">
				Originally published on {source}
			</div>
		)}
	</article>

	<!-- Hide broken images in post bodies -->
	<script>
		document.querySelectorAll('.prose img').forEach(img => {
			(img as HTMLImageElement).addEventListener('error', () => {
				img.classList.add('img-broken');
			});
		});
	</script>
</BaseLayout>

<style>
	.hero-container {
		max-height: 400px;
		overflow: hidden;
		aspect-ratio: 16 / 9;
	}

	.hero-image {
		width: 100%;
		height: 100%;
		max-height: 400px;
		object-fit: cover;
	}
</style>
