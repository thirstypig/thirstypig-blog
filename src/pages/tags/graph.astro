---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagGraph from '../../components/TagGraph.astro';
---

<BaseLayout
	title="How tags connect"
	description="A force-directed graph of every tag across the food blog's venues."
>
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<h1 class="font-serif text-3xl sm:text-4xl font-bold text-ink mb-2">
			How tags connect
		</h1>
		<p class="text-stone mb-6">
			Each dot is a Google-Maps-review tag. Lines connect tags that show up
			at the same venue. Thicker lines = more shared venues. Click a tag to
			search the blog for it.
		</p>

		<TagGraph />
	</section>
</BaseLayout>
