---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { slugify } from '../utils';
import { aggregateRegions } from '../utils/regions';
import { getImageInfo } from '../utils/image-dimensions.mjs';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('posts'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const secondary = posts.slice(1, 5);

const heroInfo = featured?.data.heroImage ? await getImageInfo(featured.data.heroImage) : null;
const secondaryInfos = await Promise.all(
	secondary.map(p => p.data.heroImage ? getImageInfo(p.data.heroImage) : Promise.resolve(null))
);

const { top: topRegions, elsewhereCount } = aggregateRegions(posts, 3);

const cityTiles = [
	...topRegions.map(({ region, count }) => ({
		label: region,
		count,
		href: `/regions/${slugify(region)}/`,
	})),
	{ label: 'Everywhere else', count: elsewhereCount, href: '/archive/' },
];

const dispatchNumber = posts.length.toLocaleString();
const featuredCategory = featured?.data.region || featured?.data.categories?.[0] || 'DISPATCH';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section
		class="relative overflow-hidden text-white"
		style="background: #E4152B;"
	>
		<div
			class="hidden md:block absolute top-0 bottom-0 right-[-40px] w-[55%] bg-no-repeat bg-center bg-cover"
			style="background-image: url('/images/redpig-transparent.png'); background-size: cover; background-position: center left;"
			aria-hidden="true"
		></div>
		<div
			class="hidden md:block absolute inset-0 pointer-events-none"
			style="background: linear-gradient(90deg, #E4152B 40%, rgba(228,21,43,0) 70%);"
			aria-hidden="true"
		></div>
		<div
			class="md:hidden absolute right-[-30px] top-5 w-56 h-56 bg-no-repeat bg-center bg-cover opacity-50 pointer-events-none"
			style="background-image: url('/images/redpig-transparent.png');"
			aria-hidden="true"
		></div>

		<div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-10 py-14 md:py-20 lg:py-24">
			<div class="font-mono text-[11px] md:text-xs tracking-[0.25em] opacity-85 uppercase">
				Dispatch №&nbsp;{dispatchNumber} · Since 2007
			</div>
			<h1
				class="m-0 mt-5 mb-6 font-black tracking-tight"
				style="font-family: 'Archivo Black', Archivo, system-ui, sans-serif; font-size: clamp(64px, 13vw, 168px); line-height: 0.86; letter-spacing: -0.04em;"
			>
				Eat<br />everything.<br />Twice.
			</h1>
			<p class="text-base md:text-xl lg:text-[22px] leading-snug max-w-md md:max-w-xl opacity-95 m-0">
				Nineteen years of dumplings, dives, and dubious cocktails across Los Angeles, the SGV, Shanghai, and anywhere else I could get a table.
			</p>
			<div class="flex flex-wrap gap-2 md:gap-3 mt-6 md:mt-9">
				{featured && (
					<a
						href={`/posts/${featured.id}/`}
						class="inline-flex items-center bg-white text-[#E4152B] px-4 md:px-5 py-2.5 md:py-3.5 rounded-full font-bold text-sm md:text-[15px] no-underline hover:bg-cream transition-colors"
					>
						Read the latest ↗
					</a>
				)}
				<a
					href="/map"
					class="inline-flex items-center border border-white/50 text-white px-4 md:px-5 py-2.5 md:py-3.5 rounded-full font-medium text-sm md:text-[15px] no-underline hover:bg-white/10 transition-colors"
				>
					Open the map
				</a>
			</div>
		</div>
	</section>

	{featured && (
		<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-10 pt-12 md:pt-16 pb-8">
			<div class="flex items-baseline justify-between mb-6 md:mb-8">
				<h2
					class="m-0 font-extrabold tracking-tight text-ink"
					style="font-family: 'Archivo', system-ui, sans-serif; font-size: clamp(24px, 4vw, 40px); letter-spacing: -0.02em;"
				>
					Right off the stove
				</h2>
				<a href="/archive/" class="text-sm font-semibold text-[#E4152B] no-underline hover:underline">
					All stories →
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7">
				<a href={`/posts/${featured.id}/`} class="md:col-span-1 md:row-span-2 group no-underline block">
					<div class="aspect-[4/5] overflow-hidden rounded-sm bg-cream-dark relative">
						{featured.data.heroImage && heroInfo ? (
							<picture>
								{heroInfo.webp && <source type="image/webp" srcset={heroInfo.webp} />}
								<img
									src={featured.data.heroImage}
									alt={featured.data.title}
									width={heroInfo.width ?? undefined}
									height={heroInfo.height ?? undefined}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
									loading="eager"
									decoding="async"
								/>
							</picture>
						) : (
							<div class="w-full h-full bg-gradient-to-br from-[#E4152B]/20 to-[#1A1413]/30 flex items-center justify-center">
								<span class="font-mono text-xs tracking-widest text-white/70 uppercase">No photo</span>
							</div>
						)}
					</div>
					<div class="mt-4 md:mt-5">
						<span class="inline-block bg-ink text-cream text-[11px] font-bold tracking-[0.1em] px-2 py-1 uppercase">
							Featured
						</span>
						<h3
							class="mt-3 mb-2 font-extrabold tracking-tight text-ink group-hover:text-[#E4152B] transition-colors leading-tight"
							style="font-family: 'Archivo', system-ui, sans-serif; font-size: clamp(22px, 3vw, 36px); letter-spacing: -0.02em;"
						>
							{featured.data.title}
						</h3>
						{featured.data.description && (
							<p class="text-sm md:text-base text-stone m-0 line-clamp-3">
								{featured.data.description}
							</p>
						)}
					</div>
				</a>

				{secondary.map((post, i) => {
					const info = secondaryInfos[i];
					const tag = post.data.region || post.data.categories?.[0] || 'POST';
					return (
						<a href={`/posts/${post.id}/`} class="group no-underline block">
							<div class="aspect-[4/3] overflow-hidden rounded-sm bg-cream-dark">
								{post.data.heroImage && info ? (
									<picture>
										{info.webp && <source type="image/webp" srcset={info.webp} />}
										<img
											src={post.data.heroImage}
											alt={post.data.title}
											width={info.width ?? undefined}
											height={info.height ?? undefined}
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
											loading="lazy"
											decoding="async"
										/>
									</picture>
								) : (
									<div class="w-full h-full bg-gradient-to-br from-amber/10 to-rust/10 flex items-center justify-center">
										<span class="font-serif text-3xl text-amber/30">TP</span>
									</div>
								)}
							</div>
							<div class="mt-3">
								<div class="text-[11px] font-bold tracking-[0.15em] text-[#E4152B] uppercase">
									{tag}
								</div>
								<h4
									class="mt-1 mb-1 font-bold leading-tight text-ink group-hover:text-[#E4152B] transition-colors"
									style="font-family: 'Archivo', system-ui, sans-serif; font-size: 18px;"
								>
									{post.data.title}
								</h4>
								<p class="text-xs text-stone m-0 font-mono">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</div>
						</a>
					);
				})}
			</div>
		</section>
	)}

	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-10 py-10 md:py-12 border-t border-cream-dark">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
			{cityTiles.map(({ label, count, href }) => (
				<a
					href={href}
					class="block relative bg-cream px-6 py-7 hover:bg-cream-dark/60 transition-colors no-underline"
				>
					<div class="text-[11px] font-bold tracking-[0.15em] text-stone uppercase">
						City · {count.toLocaleString()} posts
					</div>
					<div
						class="mt-1.5 font-extrabold tracking-tight text-ink leading-tight"
						style="font-family: 'Archivo', system-ui, sans-serif; font-size: clamp(22px, 2.5vw, 32px); letter-spacing: -0.02em;"
					>
						{label}
					</div>
					<span class="absolute right-5 top-1/2 -translate-y-1/2 text-2xl text-[#E4152B]" aria-hidden="true">→</span>
				</a>
			))}
		</div>
	</section>
</BaseLayout>
