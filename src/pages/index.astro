---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { slugify } from '../utils';
import PostGrid from '../components/PostGrid.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('posts'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = posts.slice(0, 12);

// Get unique categories with counts
const categoryMap = new Map<string, number>();
posts.forEach(post => {
	post.data.categories?.forEach(cat => {
		categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
	});
});
const topCategories = [...categoryMap.entries()]
	.sort((a, b) => b[1] - a[1])
	.slice(0, 12);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero -->
	<section class="bg-gradient-to-b from-ink to-ink/90 text-cream py-16 sm:py-24">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-cream mb-4">
				The Thirsty Pig
			</h1>
			<p class="text-lg sm:text-xl text-stone-light max-w-2xl mx-auto">
				A food, drink, and dining adventure — exploring restaurants, street food,
				cocktails, and culinary culture across Los Angeles and beyond.
			</p>
			<p class="mt-6 text-sm text-stone">
				{posts.length} posts &bull; Since 2007
			</p>
		</div>
	</section>

	<!-- Recent Posts -->
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="flex items-center justify-between mb-8">
			<h2 class="font-serif text-2xl sm:text-3xl font-bold text-ink">Recent Posts</h2>
			<a
				href="/posts/1"
				class="text-sm font-medium text-amber hover:text-rust transition-colors no-underline"
			>
				View all &rarr;
			</a>
		</div>
		<PostGrid posts={recentPosts} />
	</section>

	<!-- Quick Links -->
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-cream-dark">
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
			<a href="/best-of" class="flex items-center gap-3 p-4 rounded-xl border border-cream-dark hover:border-amber hover:bg-amber/5 transition-all no-underline group">
				<span class="text-2xl">🏆</span>
				<div>
					<span class="font-serif font-bold text-ink group-hover:text-amber transition-colors">Best Of</span>
					<p class="text-xs text-stone">Curated lists by cuisine & region</p>
				</div>
			</a>
			<a href="/map" class="flex items-center gap-3 p-4 rounded-xl border border-cream-dark hover:border-amber hover:bg-amber/5 transition-all no-underline group">
				<span class="text-2xl">📍</span>
				<div>
					<span class="font-serif font-bold text-ink group-hover:text-amber transition-colors">Map</span>
					<p class="text-xs text-stone">Explore restaurants on a map</p>
				</div>
			</a>
			<a href="/search" class="flex items-center gap-3 p-4 rounded-xl border border-cream-dark hover:border-amber hover:bg-amber/5 transition-all no-underline group">
				<span class="text-2xl">🔍</span>
				<div>
					<span class="font-serif font-bold text-ink group-hover:text-amber transition-colors">Search</span>
					<p class="text-xs text-stone">Find any restaurant or cuisine</p>
				</div>
			</a>
		</div>
	</section>

	<!-- Categories -->
	{topCategories.length > 0 && (
		<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-cream-dark">
			<h2 class="font-serif text-2xl sm:text-3xl font-bold text-ink mb-8">Explore by Category</h2>
			<div class="flex flex-wrap gap-3">
				{topCategories.map(([cat, count]) => (
					<a
						href={`/categories/${slugify(cat)}/`}
						class="px-4 py-2 border border-cream-dark rounded-full text-sm font-medium text-ink hover:border-amber hover:text-amber hover:bg-amber/5 transition-all no-underline"
					>
						{cat}
						<span class="ml-1.5 text-stone text-xs">({count})</span>
					</a>
				))}
			</div>
		</section>
	)}
</BaseLayout>
