---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hit List" description="Restaurants and places I want to try.">
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<h1 class="font-serif text-3xl sm:text-4xl font-bold text-ink mb-2">Hit List</h1>
		<p class="text-stone mb-6">Restaurants and places I want to try.</p>

		<!-- Filters -->
		<div class="flex flex-wrap gap-3 mb-8">
			<select id="city-filter" class="px-3 py-2 rounded-lg border border-cream-dark bg-cream text-ink text-sm focus:border-amber focus:ring-2 focus:ring-amber/30">
				<option value="">All cities</option>
			</select>
			<div id="tag-pills" class="flex flex-wrap gap-2"></div>
			<button id="clear-filters" class="hidden px-3 py-2 rounded-lg border border-cream-dark bg-cream text-stone text-sm hover:text-ink hover:bg-cream-dark/50 transition-colors">
				Clear filters
			</button>
		</div>

		<!-- Hit list -->
		<div>
			<h2 class="font-serif text-2xl font-bold text-ink mb-4 flex items-center gap-2">
				<span id="hitlist-count" class="text-sm font-sans font-normal text-stone"></span>
			</h2>
			<div id="hitlist-cards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
		</div>

		<!-- Empty state -->
		<div id="empty-state" class="hidden text-center py-12">
			<p class="text-stone text-lg">No places match your filters.</p>
			<button id="empty-clear" class="mt-3 text-amber hover:text-rust transition-colors text-sm">Clear filters</button>
		</div>

		<!-- Loading -->
		<div id="loading" class="text-center py-12">
			<p class="text-stone">Loading places...</p>
		</div>
	</section>
</BaseLayout>

<script>
	interface HitListItem {
		id: string;
		name: string;
		neighborhood: string;
		city: string;
		priority: number;
		dateAdded: string;
		notes: string;
		links: Record<string, string>;
		tags: string[];
	}

	interface HitListData {
		items: HitListItem[];
	}

	let data: HitListData | null = null;
	let activeCity = '';
	let activeTag = '';

	const linkLabels: Record<string, string> = {
		yelp: 'Yelp',
		google: 'Map',
		instagram: 'IG',
		resy: 'Resy',
		opentable: 'OpenTable',
		website: 'Web',
	};

	function esc(s: string): string {
		const d = document.createElement('div');
		d.textContent = s;
		return d.innerHTML;
	}

	function priorityLabel(p: number): string {
		if (p === 1) return 'Must Try';
		if (p === 3) return 'Curious';
		return '';
	}

	function renderCard(item: HitListItem): string {
		const links = Object.entries(item.links)
			.filter(([, url]) => url)
			.map(([key, url]) => {
				const label = linkLabels[key] || key.charAt(0).toUpperCase() + key.slice(1);
				return `<a href="${esc(url)}" target="_blank" rel="noopener noreferrer" class="text-amber hover:text-rust transition-colors">${esc(label)}</a>`;
			})
			.join('<span class="text-stone-light mx-1">·</span>');

		const badge = priorityLabel(item.priority);
		const tags = item.tags
			.map(t => `<span class="text-xs text-stone bg-cream-dark px-2 py-0.5 rounded-full">${esc(t)}</span>`)
			.join('');

		return `
			<div class="bg-cream-dark/70 rounded-xl border border-cream-dark p-5 hover:shadow-md transition-shadow">
				<div class="flex items-start justify-between mb-1">
					<h3 class="font-serif text-lg font-semibold text-ink leading-snug">${esc(item.name)}</h3>
					${badge ? `<span class="shrink-0 ml-2 text-xs font-medium px-2 py-0.5 rounded-full ${item.priority === 1 ? 'bg-amber/10 text-amber' : 'bg-cream-dark text-stone'}">${badge}</span>` : ''}
				</div>
				<p class="text-sm text-stone mb-2">${esc(item.neighborhood ? `${item.neighborhood}, ${item.city}` : item.city)}</p>
				${item.notes ? `<p class="text-sm text-ink-light mb-3">${esc(item.notes)}</p>` : ''}
				${links ? `<div class="text-xs flex flex-wrap items-center gap-0 mb-2">${links}</div>` : ''}
				${tags ? `<div class="flex flex-wrap gap-1.5 mt-2">${tags}</div>` : ''}
			</div>
		`;
	}

	function render() {
		if (!data) return;

		let items = data.items;

		if (activeCity) items = items.filter(i => i.city === activeCity);
		if (activeTag) items = items.filter(i => i.tags.includes(activeTag));

		const cardsEl = document.getElementById('hitlist-cards')!;
		const countEl = document.getElementById('hitlist-count')!;
		const emptyState = document.getElementById('empty-state')!;

		cardsEl.innerHTML = items.map(renderCard).join('');
		countEl.textContent = `${items.length} ${items.length === 1 ? 'place' : 'places'}`;

		emptyState.classList.toggle('hidden', items.length > 0);
		cardsEl.classList.toggle('hidden', items.length === 0);

		const clearBtn = document.getElementById('clear-filters')!;
		clearBtn.classList.toggle('hidden', !activeCity && !activeTag);
	}

	function buildFilters() {
		if (!data) return;

		const cities = [...new Set(data.items.map(i => i.city))].sort();
		const tags = [...new Set(data.items.flatMap(i => i.tags))].sort();

		const citySelect = document.getElementById('city-filter') as HTMLSelectElement;
		cities.forEach(c => {
			const opt = document.createElement('option');
			opt.value = c;
			opt.textContent = c;
			citySelect.appendChild(opt);
		});

		const tagContainer = document.getElementById('tag-pills')!;
		tags.forEach(t => {
			const btn = document.createElement('button');
			btn.textContent = t;
			btn.className = 'text-xs px-3 py-1.5 rounded-full border border-cream-dark text-stone hover:text-ink hover:bg-cream-dark/50 transition-colors';
			btn.dataset.tag = t;
			btn.addEventListener('click', () => {
				activeTag = activeTag === t ? '' : t;
				updateTagStyles();
				render();
			});
			tagContainer.appendChild(btn);
		});
	}

	function updateTagStyles() {
		const buttons = document.querySelectorAll('#tag-pills button') as NodeListOf<HTMLButtonElement>;
		buttons.forEach(btn => {
			const isActive = btn.dataset.tag === activeTag;
			btn.className = isActive
				? 'text-xs px-3 py-1.5 rounded-full border border-amber bg-amber/10 text-amber font-medium transition-colors'
				: 'text-xs px-3 py-1.5 rounded-full border border-cream-dark text-stone hover:text-ink hover:bg-cream-dark/50 transition-colors';
		});
	}

	async function init() {
		try {
			const resp = await fetch('/places-hitlist.json');
			if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
			data = await resp.json();

			document.getElementById('loading')!.classList.add('hidden');

			buildFilters();
			render();

			document.getElementById('city-filter')!.addEventListener('change', (e) => {
				activeCity = (e.target as HTMLSelectElement).value;
				render();
			});

			document.getElementById('clear-filters')!.addEventListener('click', clearFilters);
			document.getElementById('empty-clear')!.addEventListener('click', clearFilters);
		} catch {
			document.getElementById('loading')!.innerHTML = '<p class="text-stone">Could not load hit list data.</p>';
		}
	}

	function clearFilters() {
		activeCity = '';
		activeTag = '';
		(document.getElementById('city-filter') as HTMLSelectElement).value = '';
		updateTagStyles();
		render();
	}

	init();
</script>
