---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Chip {
	label: string;
	mention_count: number;
}

interface VenueRecord {
	place_id: string;
	venue_name: string;
	city: string | null;
	key: string | null;
	chips: Chip[];
	scraped_at: string;
}

// Read all published venue chip files at build time. Source of truth is
// public/venue-tags/, which scripts/venue-tags/publish.py writes to. If
// it's empty, prompt the maintainer to run the scraper + publisher.
const venueDir = path.join(process.cwd(), 'public', 'venue-tags');
let venues: VenueRecord[] = [];
if (fs.existsSync(venueDir)) {
	venues = fs
		.readdirSync(venueDir)
		.filter(f => f.endsWith('.json'))
		.map(f => JSON.parse(fs.readFileSync(path.join(venueDir, f), 'utf-8')) as VenueRecord)
		.sort((a, b) => (a.city || '').localeCompare(b.city || ''));
}

// Sort each venue's chips by mention_count descending so the heaviest tags
// render first.
venues = venues.map(v => ({
	...v,
	chips: [...v.chips].sort((a, b) => b.mention_count - a.mention_count),
}));

const totalChips = venues.reduce((sum, v) => sum + v.chips.length, 0);
const formatCount = (n: number) => n.toLocaleString('en-US');
---

<BaseLayout
	title="Venue Tags"
	description="Topic chips scraped from Google Maps reviews — a per-venue tag system MVP."
>
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<header class="mb-10">
			<h1 class="font-serif text-3xl sm:text-4xl font-bold text-ink mb-2">Venue Tags</h1>
			<p class="text-stone max-w-2xl">
				Per-venue tags scraped from Google Maps' "Refine reviews" topic chips.
				MVP slice — {venues.length} venues, {totalChips} chips total.
			</p>
		</header>

		{venues.length === 0 ? (
			<div class="bg-cream-dark/50 border border-cream-dark rounded-lg p-6">
				<p class="text-stone">
					No chip data yet. Run the scraper:
				</p>
				<pre class="mt-3 text-sm font-mono bg-ink text-cream rounded p-3 overflow-x-auto"><code>scripts/venue-tags/venv/bin/python scripts/venue-tags/scrape_google.py
scripts/venue-tags/venv/bin/python scripts/venue-tags/publish.py</code></pre>
			</div>
		) : (
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{venues.map(v => (
					<article class="bg-cream-dark/30 border border-cream-dark rounded-lg p-6 flex flex-col">
						<header class="mb-4">
							<h2 class="font-serif text-xl font-bold text-ink leading-tight">
								{v.venue_name}
							</h2>
							{v.city && (
								<p class="text-stone text-sm mt-1">{v.city}</p>
							)}
						</header>

						<div class="flex flex-wrap gap-2 mb-4">
							{v.chips.map(chip => (
								<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-cream border border-cream-dark text-sm">
									<span class="text-ink">{chip.label}</span>
									<span class="text-stone text-xs font-mono">{formatCount(chip.mention_count)}</span>
								</span>
							))}
						</div>

						<footer class="mt-auto pt-3 border-t border-cream-dark/50 flex items-center justify-between text-xs text-stone">
							<span class="font-mono truncate" title={v.place_id}>
								{v.place_id.slice(0, 18)}…
							</span>
							<a
								href={`/venue-tags/${v.place_id}.json`}
								class="text-amber hover:text-rust transition-colors"
							>
								raw JSON →
							</a>
						</footer>
					</article>
				))}
			</div>
		)}

		<footer class="mt-10 text-xs text-stone">
			<p>
				Scraped via <code class="font-mono">scripts/venue-tags/scrape_google.py</code>.
				See <code class="font-mono">scripts/venue-tags/README.md</code> for the
				architecture. Per-venue JSON is served at
				<code class="font-mono">/venue-tags/&#123;place_id&#125;.json</code>.
			</p>
		</footer>
	</section>
</BaseLayout>
