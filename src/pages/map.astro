---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Map" description="Explore restaurants on a map — The Thirsty Pig food blog.">
	<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<h1 class="font-serif text-3xl sm:text-4xl font-bold text-ink mb-2">Restaurant Map</h1>
		<p class="text-stone mb-6">Explore all the places we've eaten, across LA and around the world.</p>

		<!-- Legend -->
		<div class="flex flex-wrap gap-4 mb-3 text-sm" aria-label="Map legend">
			<span class="inline-flex items-center gap-2 text-stone">
				<svg class="w-4 h-4" viewBox="0 0 16 16" aria-hidden="true">
					<circle cx="8" cy="8" r="6" fill="#B45309" stroke="#fff" stroke-width="1.5" />
				</svg>
				Open
			</span>
			<span class="inline-flex items-center gap-2 text-stone">
				<svg class="w-4 h-4" viewBox="0 0 16 16" aria-hidden="true">
					<circle cx="8" cy="8" r="6" fill="none" stroke="#9A3412" stroke-width="2" stroke-dasharray="2 2" />
				</svg>
				Closed
			</span>
		</div>

		<!-- Map container -->
		<div id="map" class="w-full h-[500px] sm:h-[600px] rounded-xl border border-cream-dark shadow-sm mb-4"></div>
		<p id="map-count" class="text-sm text-stone"></p>
	</section>

	<script>
		import L from 'leaflet';
		import 'leaflet/dist/leaflet.css';

		interface MapMarker {
			id: string;
			title: string;
			lat: number;
			lng: number;
			city?: string;
			region?: string;
			location?: string;
			heroImage?: string;
			date: string;
			closed?: boolean;
			hasExactCoords?: boolean;
		}

		async function initMap() {
			const resp = await fetch('/map.json');
			const markers: MapMarker[] = await resp.json();

			const map = L.map('map').setView([34.05, -118.25], 10);

			L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
				attribution: '&copy; OpenStreetMap contributors',
				maxZoom: 18,
			}).addTo(map);

			const markerGroup = L.featureGroup();

			function getRadius(zoom: number): number {
				if (zoom <= 3) return 4;
				if (zoom <= 5) return 5;
				if (zoom <= 8) return 6;
				return 7;
			}

			function esc(s: string): string {
				const d = document.createElement('div');
				d.textContent = s;
				return d.innerHTML;
			}

			const allMarkers: L.CircleMarker[] = [];

			markers.forEach((m) => {
				// Shape-differentiate closed markers so colorblind users can tell them
				// apart from open ones: closed = dashed hollow ring, open = filled disc.
				const marker = m.closed
					? L.circleMarker([m.lat, m.lng], {
						radius: getRadius(map.getZoom()),
						fillOpacity: 0,
						color: '#9A3412',
						weight: 2,
						dashArray: '2 2',
					})
					: L.circleMarker([m.lat, m.lng], {
						radius: getRadius(map.getZoom()),
						fillColor: '#B45309',
						color: '#fff',
						weight: 1.5,
						opacity: 1,
						fillOpacity: 0.85,
					});
				allMarkers.push(marker);

				const safeTitle = esc(m.title || '');
				const safeId = esc(m.id || '');
				const safeLocation = esc(m.location || '');
				const safeCity = esc(m.city || '');
				const safeRegion = esc(m.region || '');
				const safeImage = m.heroImage ? esc(m.heroImage) : '';

				const imgHtml = safeImage
					? `<img src="${safeImage}" alt="${safeTitle}" style="width:200px;height:130px;object-fit:cover;border-radius:6px;margin-bottom:6px;" loading="lazy" />`
					: '';
				const closedBadge = m.closed
					? '<span style="color:#9A3412;font-weight:bold;font-size:11px;"> CLOSED</span>'
					: '';

				const locationLine = safeLocation && safeLocation !== safeTitle
					? `<div style="font-size:12px;color:#B45309;margin-top:2px;">${safeLocation}</div>`
					: '';
				const gpsIcon = m.hasExactCoords
					? '<span title="Exact GPS location" style="font-size:10px;">📍</span> '
					: '';

				marker.bindPopup(`
					<div style="max-width:220px;font-family:system-ui;">
						${imgHtml}
						<a href="/posts/${safeId}/" style="font-weight:600;font-size:14px;color:#1A1A1A;text-decoration:none;">
							${safeTitle}${closedBadge}
						</a>
						${locationLine}
						<div style="font-size:12px;color:#655F5B;margin-top:4px;">
							${gpsIcon}${safeCity}${safeRegion && safeRegion !== safeCity ? ' · ' + safeRegion : ''} · ${m.date}
						</div>
					</div>
				`);

				markerGroup.addLayer(marker);
			});

			markerGroup.addTo(map);

			if (markers.length > 0) {
				map.fitBounds(markerGroup.getBounds().pad(0.1));
			}

			map.on('zoomend', () => {
				const r = getRadius(map.getZoom());
				allMarkers.forEach(m => m.setRadius(r));
			});

			document.getElementById('map-count')!.textContent =
				`${markers.length} restaurants mapped`;
		}

		initMap();
	</script>
</BaseLayout>
