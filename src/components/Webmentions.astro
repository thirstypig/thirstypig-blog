---
// Renders webmentions for a given target URL. Data source: src/data/webmentions.json,
// populated at build time by scripts/fetch-webmentions.mjs.
//
// Facepile (likes, reposts, bookmarks) compresses many small signals into a
// single row of avatars. Reply-style mentions (in-reply-to, mention-of) get
// rendered as short threaded entries with content.

import webmentionData from '../data/webmentions.json';
import FormattedDate from './FormattedDate.astro';

interface Props {
	target: string;
}

const { target } = Astro.props;

type Mention = {
	id: number;
	target: string;
	source: string;
	type: 'reply' | 'like' | 'repost' | 'mention' | 'bookmark';
	author: { name: string | null; url: string | null; photo: string | null };
	content: string | null;
	published: string | null;
};

// Normalize trailing slash on both sides so /posts/x and /posts/x/ both match.
const normalize = (u: string) => u.replace(/\/+$/, '');
const normalizedTarget = normalize(target);

const all = (webmentionData.mentions as Mention[]).filter(
	m => normalize(m.target) === normalizedTarget
);

const facepile = all.filter(m => m.type === 'like' || m.type === 'repost' || m.type === 'bookmark');
const threaded = all
	.filter(m => m.type === 'reply' || m.type === 'mention')
	.sort((a, b) => (a.published || '').localeCompare(b.published || ''));

const FACEPILE_LABEL: Record<string, string> = {
	like: 'liked this',
	repost: 'shared this',
	bookmark: 'bookmarked this',
};
---

{all.length > 0 && (
	<section class="mt-12 pt-8 border-t border-cream-dark">
		<h2 class="font-serif text-xl font-bold text-ink mb-6">
			Responses from around the web
		</h2>

		{facepile.length > 0 && (
			<div class="mb-6">
				<div class="flex flex-wrap items-center gap-2">
					{facepile.map(m => (
						<a
							href={m.author.url || m.source}
							target="_blank"
							rel="noopener noreferrer ugc"
							class="no-underline"
							title={`${m.author.name || 'Someone'} ${FACEPILE_LABEL[m.type] || 'responded'}`}
						>
							{m.author.photo ? (
								<img
									src={m.author.photo}
									alt={m.author.name || ''}
									width="32"
									height="32"
									loading="lazy"
									decoding="async"
									class="w-8 h-8 rounded-full border border-cream-dark"
								/>
							) : (
								<div class="w-8 h-8 rounded-full bg-cream-dark flex items-center justify-center text-xs font-bold text-stone">
									{(m.author.name || '?').slice(0, 1).toUpperCase()}
								</div>
							)}
						</a>
					))}
				</div>
			</div>
		)}

		{threaded.length > 0 && (
			<ol class="space-y-6 list-none p-0">
				{threaded.map(m => (
					<li class="flex gap-3">
						<a
							href={m.author.url || m.source}
							target="_blank"
							rel="noopener noreferrer ugc"
							class="flex-shrink-0 no-underline"
						>
							{m.author.photo ? (
								<img
									src={m.author.photo}
									alt={m.author.name || ''}
									width="40"
									height="40"
									loading="lazy"
									decoding="async"
									class="w-10 h-10 rounded-full border border-cream-dark"
								/>
							) : (
								<div class="w-10 h-10 rounded-full bg-cream-dark flex items-center justify-center text-sm font-bold text-stone">
									{(m.author.name || '?').slice(0, 1).toUpperCase()}
								</div>
							)}
						</a>
						<div class="flex-1 min-w-0">
							<div class="flex items-baseline gap-2 text-sm">
								<a
									href={m.author.url || m.source}
									target="_blank"
									rel="noopener noreferrer ugc"
									class="font-semibold text-ink hover:text-amber no-underline"
								>
									{m.author.name || 'Someone'}
								</a>
								<a
									href={m.source}
									target="_blank"
									rel="noopener noreferrer ugc"
									class="text-xs text-stone hover:text-amber no-underline"
								>
									{m.published && <FormattedDate date={new Date(m.published)} />}
								</a>
							</div>
							{m.content && (
								<p class="text-sm text-ink mt-1 leading-relaxed break-words">
									{m.content}
								</p>
							)}
						</div>
					</li>
				))}
			</ol>
		)}
	</section>
)}
