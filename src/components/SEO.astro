---
import { SITE_TITLE, SITE_URL } from '../consts';
import { slugify } from '../utils';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishDate?: Date;
	categories?: string[];
	location?: string;
	address?: string;
	coordinates?: { lat: number; lng: number };
	city?: string;
	region?: string;
}

const {
	title,
	description = 'A food, drink, and dining adventure blog exploring restaurants, street food, cocktails, and culinary culture.',
	image,
	type = 'website',
	publishDate,
	categories = [],
	location,
	address,
	coordinates,
	city,
	region,
} = Astro.props;

const siteBase = Astro.site || SITE_URL;
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const fullTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const ogImage = image ? new URL(image, siteBase).toString() : undefined;

const isHomepage = Astro.url.pathname === '/';
const primaryCategory = categories[0];

// --- Structured data ------------------------------------------------------

// Restaurant LD when we have venue data
const hasRestaurant = location && (address || coordinates);
const restaurantLD = hasRestaurant ? {
	'@context': 'https://schema.org',
	'@type': 'Restaurant',
	name: location,
	...(address && { address: {
		'@type': 'PostalAddress',
		streetAddress: address,
		...(city && { addressLocality: city }),
		...(region && { addressRegion: region }),
	}}),
	...(coordinates && { geo: {
		'@type': 'GeoCoordinates',
		latitude: coordinates.lat,
		longitude: coordinates.lng,
	}}),
	...(ogImage && { image: ogImage }),
} : null;

// Article LD for post pages (type === 'article')
const articleLD = (type === 'article' && publishDate) ? {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: publishDate.toISOString(),
	author: { '@type': 'Person', name: 'The Thirsty Pig' },
	publisher: { '@type': 'Organization', name: SITE_TITLE },
	...(ogImage && { image: ogImage }),
	...(primaryCategory && { articleSection: primaryCategory }),
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
} : null;

// BreadcrumbList LD for post pages with a known category.
// SERPs render this as Home › Category › Post beneath the title.
const breadcrumbLD = (type === 'article' && primaryCategory) ? {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: siteBase.toString().replace(/\/$/, '') + '/' },
		{ '@type': 'ListItem', position: 2, name: primaryCategory, item: new URL(`/categories/${slugify(primaryCategory)}/`, siteBase).toString() },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.toString() },
	],
} : null;

// WebSite LD with SearchAction — homepage only.
// Tells Google about the internal search so it can render a search box in
// the site's SERP result (sitelinks search box feature).
const websiteLD = isHomepage ? {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: siteBase.toString(),
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: new URL('/search?q={search_term_string}', siteBase).toString(),
		},
		'query-input': 'required name=search_term_string',
	},
} : null;
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta property="og:site_name" content={SITE_TITLE} />

<!-- Twitter -->
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- Article metadata -->
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{categories.map(cat => <meta property="article:tag" content={cat} />)}

{/* Escape `<` in JSON-LD payload so frontmatter never closes the script
   block early. JSON.stringify does NOT escape `<` by default. */}

<!-- JSON-LD: WebSite + SearchAction (homepage only, enables SERP search box) -->
{websiteLD && (
	<script type="application/ld+json" set:html={JSON.stringify(websiteLD).replace(/</g, '\\u003c')} />
)}

<!-- JSON-LD: Article (post pages) -->
{articleLD && (
	<script type="application/ld+json" set:html={JSON.stringify(articleLD).replace(/</g, '\\u003c')} />
)}

<!-- JSON-LD: BreadcrumbList (post pages with a category) -->
{breadcrumbLD && (
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD).replace(/</g, '\\u003c')} />
)}

<!-- JSON-LD: Restaurant (venue pages with location + address or coords) -->
{restaurantLD && (
	<script type="application/ld+json" set:html={JSON.stringify(restaurantLD).replace(/</g, '\\u003c')} />
)}
