---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
	{ href: '/archive/', label: 'Stories', isActive: pathname.startsWith('/archive') },
	{ href: '/cities', label: 'Cities', isActive: pathname.startsWith('/cities') },
	{ href: '/map', label: 'Map', isActive: pathname === '/map' },
	{ href: '/best-of', label: 'Cuisine', isActive: pathname.startsWith('/best-of') },
	{ href: '/hitlist', label: 'Hit List', isActive: pathname === '/hitlist' },
	{ href: '/about', label: 'About', isActive: pathname === '/about' },
];

const mobileExtras = [
	{ href: '/search', label: 'Search', isActive: pathname === '/search' },
];
---

<header class="bg-cream sticky top-0 z-50 border-b border-cream-dark/50">
	<nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
		<div class="flex items-center justify-between h-16 gap-4">
			<a href="/" class="flex items-center gap-2 no-underline group text-ink shrink-0">
				<span
					class="block h-10 w-10 rounded-full shrink-0 bg-[#E4152B] bg-no-repeat bg-center"
					style="background-image: url('/images/redpig-transparent.png'); background-size: 110%; box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08);"
					aria-label={SITE_TITLE}
				></span>
				<span class="font-[Archivo,system-ui,sans-serif] font-extrabold text-lg tracking-tight text-ink hidden sm:inline">
					thirsty<span class="text-[#E4152B]">pig</span>
				</span>
			</a>

			<div class="hidden md:flex items-center gap-7">
				{navItems.map(({ href, label, isActive }) => (
					<a
						href={href}
						aria-current={isActive ? 'page' : undefined}
						class:list={[
							'text-sm font-medium transition-colors no-underline',
							isActive ? 'text-[#E4152B]' : 'text-ink hover:text-[#E4152B]'
						]}
					>
						{label}
					</a>
				))}
			</div>

			<div class="flex items-center gap-2 shrink-0">
				<form action="/search" method="get" class="hidden lg:block">
					<input
						type="search"
						name="q"
						placeholder="Search posts"
						aria-label="Search posts"
						class="px-3 py-1.5 rounded-full border border-cream-dark/70 text-sm bg-transparent text-ink placeholder:text-stone w-44 focus:outline-none focus:border-[#E4152B]"
					/>
				</form>

				<button
					id="theme-toggle"
					type="button"
					class="p-2 rounded-lg text-stone hover:text-ink hover:bg-cream-dark/50 transition-colors"
					aria-label="Toggle dark mode"
					aria-pressed="false"
				>
					<svg id="theme-icon-sun" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
					</svg>
					<svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
					</svg>
				</button>

				<button
					id="mobile-menu-btn"
					type="button"
					class="md:hidden p-2 rounded-lg text-stone hover:text-ink hover:bg-cream-dark/50"
					aria-label="Toggle menu"
					aria-expanded="false"
					aria-controls="mobile-menu"
				>
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
		</div>

		<div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-cream-dark/50">
			<div class="flex flex-col gap-1 pt-2">
				{[...navItems, ...mobileExtras].map(({ href, label, isActive }) => (
					<a
						href={href}
						aria-current={isActive ? 'page' : undefined}
						class:list={[
							'px-3 py-2 rounded-lg text-sm font-medium no-underline',
							isActive ? 'bg-[#E4152B]/10 text-[#E4152B]' : 'text-stone hover:text-ink hover:bg-cream-dark/50'
						]}
					>
						{label}
					</a>
				))}
			</div>
		</div>
	</nav>
</header>

<script>
	const menuBtn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	menuBtn?.addEventListener('click', () => {
		const isOpen = !menu?.classList.contains('hidden');
		menu?.classList.toggle('hidden');
		menuBtn.setAttribute('aria-expanded', String(!isOpen));
	});

	const themeBtn = document.getElementById('theme-toggle');

	function updateThemeUI() {
		const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
		document.getElementById('theme-icon-sun')!.classList.toggle('hidden', !isDark);
		document.getElementById('theme-icon-moon')!.classList.toggle('hidden', isDark);
		themeBtn?.setAttribute('aria-pressed', String(isDark));
		themeBtn?.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
	}

	themeBtn?.addEventListener('click', () => {
		const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
		const next = isDark ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
		updateThemeUI();
	});

	updateThemeUI();
</script>
