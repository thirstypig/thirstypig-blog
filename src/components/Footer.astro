---
const today = new Date();
---

<footer class="bg-ink text-stone-light mt-16">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="text-center">
			<p class="font-serif text-xl text-cream mb-2">The Thirsty Pig</p>
			<p class="text-sm text-stone">
				A food, drink, and dining adventure blog.
			</p>
			<p class="text-xs text-stone mt-6">
				&copy; {today.getFullYear()} The Thirsty Pig. All rights reserved.
			</p>
		</div>
	</div>
</footer>
